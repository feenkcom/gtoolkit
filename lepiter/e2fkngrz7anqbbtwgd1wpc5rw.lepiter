					"uidString" : "r/haPORiQmimPvkPns2HXw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "The GBS replicationSpec is a client side specification that has to be configured for each session, and updated if required."
			},
