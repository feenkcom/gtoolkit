				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "#Best practices"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
