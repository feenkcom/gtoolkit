							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "9eGHS0ZBTHu1XCbmyhK/wA=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "The basic chat has no notion of the expected output. With services that offer structured output, we can define the expected schema of the response. For example, in the previous chat, we received a plain string that is shown as a plain string even if it has Markdown notation inside. If we specify that we expect Markdown, we can do so through {{gtMethod:GtLChat>>#markdownResponse}}:"
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-03-04T22:41:48.693731+01:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-03-04T23:10:19.135991+01:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "d3aR59JpTzSlF0+6ewLVXg=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Executing this chat now shows a Markdown-specific view, in addition to the plain-string content one. This is achieved in the following way: the engine sends the expected response schema in the request, and when the response comes, it transparently instantiates objects that conform to the specified schema. In our case, the object is an instance of {{gtClass:GtLMarkdown}}, and such an object knows how to present itself with a styled editor."
						}
					]
				},
