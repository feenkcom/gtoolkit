								"__type" : "textStyle"
							},
							"string" : "Structured output can be exploited for various purposes."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [
									{
										"__type" : "pharoSnippet",
