								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-03-13T22:15:05.948705+01:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "NPjzndoTT1WfU6whlXzSGQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "If the chat is successful, we should see the side effect in our variable external to the chat:"
						},
						{
