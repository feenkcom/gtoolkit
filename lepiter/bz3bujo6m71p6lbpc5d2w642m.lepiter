							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "**7. State uncertainty explicitly:**  If confidence is limited, say so and provide 1–2 options with tradeoffs."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
