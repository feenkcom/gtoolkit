							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "**8. Do not hide assumptions:**  List assumptions before coding; request confirmation for risky or ambiguous ones."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
