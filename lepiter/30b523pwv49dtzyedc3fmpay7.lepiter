				"uid" : {
					"__type" : "uid",
					"uidString" : "s7Y76HxdSMCh4Az6IgvDRg=="
				},
				"code" : "command context input: 'How long does delivery take?'.\rqueryEmbeddings := command perform.\rqueryLlmEmbedding := GtLlmEmbedding new\r\tinput: command context input;\r\tembedding: queryEmbeddings embeddings first.\r\rllmEmbeddings := (1 to: embeddings input size) collect: [ :i |\r\tGtLlmEmbedding new\r\t\tinput: (embeddings input at: i);\r\t\tembedding: (embeddings embeddings at: i) ].\rdistances := GtLlmEmbeddingsUtilities\r\t\tdistancesFromEmbeddings: llmEmbeddings\r\t\tto: queryLlmEmbedding.\rsorted := distances sorted: #distance ascending.\rsorted first embedding input."
			},
