				"code" : "provider := GtLOllamaProvider new modelName: 'gemma3:27b-cloud'.\nprovider\n\tendpoint: #generate;\n\tbaseUrl: 'https://ollama.com' asZnUrl;\n\tloadApiKeyFromFile.\nchat := GtLChat new provider: provider.\nchat sendString: 'Hi, who are you?'"
