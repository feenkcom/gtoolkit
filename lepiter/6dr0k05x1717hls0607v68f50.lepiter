					"uidString" : "0RlVY6y4RmSDirVNo4PXLQ=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Consider [AWS LZA](https://docs.aws.amazon.com/solutions/landing-zone-accelerator-on-aws/) (Landing Zone Accelerator), an open-source project that helps organizations implement advanced compliance requirements on AWS. The project is advertised as a low-code solution for defining an environment through a set of configuration files."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-04T14:18:27.452295+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-04T14:26:22.802839+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "irw/Ggo+Qt6Dfvb6qm4Ehw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "These configuration files are written in YAML. The challenge is that they define many concepts, parameters, and relationships across different AWS services. Even a small change can have significant repercussions."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
