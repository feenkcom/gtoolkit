				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Configurations are sources too, and they should be supported by dedicated tools as well."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
