						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-06-11T10:50:09.150447-05:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
