							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "gpZM/s4XQ52gcR+aW8eF7Q=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Whenever you change fields in a response object, update the JSON examples in the tool `#description` to reflect the new schema.\n\n**Checklist:**\n1. Update domain object fields.\n2. Update tool `#description` JSON response example.\n3. Update serialization example(s)."
						}
					]
				},
