					"uidString" : "qEIPG6UBRsuecFM71hn33g=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "For example, to allow the LLM to answer questions about how `Ludo` is used in the book, we can add tools for searching through Lepiter:"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-12T11:33:21.970617+01:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-03-13T22:29:56.454241+01:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "/xc79t/ISL+Ua37l2Ni0gw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "To answer our question, the LLM first needs to read the relevant pages from the book. To read them, it needs to find them in the book. To know which knowledge base the book is in, it needs to retrieve the available knowledge bases. Each of these steps should be accessible through tools. For example, the last step is supported by {{gtClass:GtLToolForLepiterKnowledgeBases}}."
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
