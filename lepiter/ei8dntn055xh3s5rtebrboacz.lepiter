				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "To transform the chat into an \"agent\", we can provide tools that the LLM can choose to run."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [
